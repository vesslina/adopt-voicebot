# Скопируй этот файл в .env или редактируй уже созданный .env.
# run.bat автоматически подхватывает .env при старте.

VOICEBOT_HOST=0.0.0.0
VOICEBOT_PORT=8090

VOICEBOT_WHISPER_MODEL=small
VOICEBOT_WHISPER_DEVICE=cuda
VOICEBOT_WHISPER_COMPUTE_TYPE=float16

VOICEBOT_OLLAMA_URL=http://localhost:11434/api/chat
VOICEBOT_OLLAMA_TAGS_URL=http://localhost:11434/api/tags
VOICEBOT_OLLAMA_MODEL=qwen3:8b
VOICEBOT_COMPANY_NAME=ISP Client
VOICEBOT_COMPANY_TTS_NAME=интернет-провайдер

VOICEBOT_TTS_SPEAKER=baya
VOICEBOT_TTS_SAMPLE_RATE=48000
VOICEBOT_TTS_MODEL_ID=v5_5_ru
VOICEBOT_TTS_MODEL_PATH=D:\voicebot\system\models\v5_5_ru.pt
VOICEBOT_TTS_MODEL_URL=https://models.silero.ai/models/tts/ru/v5_5_ru.pt

VOICEBOT_DEMO_CALLER_ID=1001
VOICEBOT_BARGE_IN_GRACE_SEC=0.2
VOICEBOT_BARGE_IN_CONSECUTIVE_CHUNKS=4
